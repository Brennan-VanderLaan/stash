{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# Security headers applied to every response. Layered defenses:
	#   - HSTS forces HTTPS for the next year (preload-eligible).
	#   - nosniff stops browsers from rendering uploaded bytes as anything
	#     other than the declared Content-Type — closes the residual upload
	#     XSS path even if a fallback served odd bytes.
	#   - frame-ancestors 'none' blocks clickjacking (modern X-Frame-Options).
	#   - Permissions-Policy locks down camera/mic/geo/FLoC at the platform
	#     level — the app doesn't need any of these.
	#   - Referrer-Policy avoids leaking the path (which can carry IDs)
	#     to third-party assets.
	#   - -Server hides "Caddy" from response headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Content-Security-Policy "frame-ancestors 'none'"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		-Server
	}

	# Backup restore needs to accept multi-GB zips (db + every photo). Scoped
	# to just the import endpoint so the photo-upload paths keep their tighter
	# 50 MB cap as a defense-in-depth ceiling on hostile uploads.
	@import {
		method POST
		path /maintenance/import
	}
	handle @import {
		request_body {
			max_size 2GB
		}
		reverse_proxy oauth2-proxy:4180 {
			header_up X-Real-IP {remote_host}
			# Long uploads + DB swap can run for minutes on slow links.
			transport http {
				read_timeout 30m
				write_timeout 30m
			}
		}
	}

	# Photos can be a few MB; let oauth2-proxy + stash handle large ingest uploads.
	handle {
		request_body {
			max_size 50MB
		}
		reverse_proxy oauth2-proxy:4180 {
			header_up X-Real-IP {remote_host}
		}
	}
}
