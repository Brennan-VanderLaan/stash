{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# Edge security headers — layered defenses.
	#
	# The app's middleware (see ``_SECURITY_HEADERS`` in app.py)
	# already stamps a richer set of headers — including the full
	# Content-Security-Policy with ``default-src``, ``script-src``,
	# ``form-action``, etc.  We deliberately do NOT re-declare CSP
	# here because Caddy's ``header`` directive defaults to
	# *replace*, which would clobber the app's comprehensive policy
	# with whatever short string we wrote on this side.  An older
	# pass shipped ``Content-Security-Policy "frame-ancestors 'none'"``
	# at the edge; in production that overrode the app's CSP and
	# dropped script-src / object-src / form-action / etc.
	#
	# What we DO set here is strictly additive (HSTS — only valid
	# over TLS, so it's an edge concern by definition; ``-Server``
	# to suppress Caddy's identifier).  Everything else is fine to
	# leave to the app so the policy is defined in exactly one
	# place.
	#
	# When you do need to add a header here, prefer the ``?Name``
	# form (set if missing) so the app's value still wins:
	#     header ?Permissions-Policy "camera=()"
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	# Body-size policy:
	#   - /maintenance/import takes whole-database backups. Cap at 2 GB.
	#   - Everything else stays at 50 MB so a hostile photo upload can't fill
	#     disk before the in-app size guard rejects it.
	# Both request_body directives wrap the body reader, so an unmatched 50 MB
	# rule would clamp the import path back down to 50 MB even with the 2 GB
	# rule above it. The `not` matcher makes the two mutually exclusive.
	@import path /maintenance/import
	@notimport not path /maintenance/import
	request_body @import {
		max_size 2GB
	}
	request_body @notimport {
		max_size 50MB
	}

	reverse_proxy oauth2-proxy:4180 {
		header_up X-Real-IP {remote_host}
	}
}
