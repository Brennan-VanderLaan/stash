# =============================================================================
# Stash deploy config
# Copy to .env and fill in.  Anything sensitive lives here, not in git.
# =============================================================================

# ----- Domain & TLS ----------------------------------------------------------

# The hostname you'll visit in the browser.  Must have a DNS A record pointing
# at this server's public IP before you start the stack — Caddy needs to
# answer an ACME HTTP-01 challenge on :80 to get a Let's Encrypt cert.
DOMAIN=stash.example.com

# Used for Let's Encrypt account registration + cert expiry warnings.
ACME_EMAIL=you@example.com

# ----- Image -----------------------------------------------------------------

# REQUIRED — the compose file errors out if this is unset.  There is
# intentionally no ``:latest`` tag published; every production cutover
# is a deliberate operator action (see CICD.md for the rationale).
#
# Production: pin to a specific release tag.  Find the latest at
#   https://github.com/Brennan-VanderLaan/stash/releases
# and bump this value each time you cut over:
#   STASH_IMAGE=ghcr.io/brennan-vanderlaan/stash:v1.48.0
#
# Staging: pin to the ``:dev`` floating tag.  Combined with the
# WATCHTOWER_PERIODIC_POLLS setting below, watchtower auto-pulls
# every dev-branch push within minutes:
#   STASH_IMAGE=ghcr.io/brennan-vanderlaan/stash:dev
STASH_IMAGE=

# ----- App secrets -----------------------------------------------------------

# Same values you use locally — copy from your dev .env.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ----- In-app updates --------------------------------------------------------

# Shared secret between stash and watchtower for the "Check for updates"
# button.  Generate with:  openssl rand -hex 32
WATCHTOWER_TOKEN=changeme

# Auto-pull loop.  Off by default (prod model — every cutover is a
# deliberate operator action through the in-app button).  Turn ON
# for staging so dev-branch pushes land within minutes without an
# operator in the loop:
#
#   WATCHTOWER_PERIODIC_POLLS=true
#   WATCHTOWER_POLL_INTERVAL=300        # seconds (5 min)
#
# Leave these unset (or false / 86400) on prod.  The HTTP API
# "Check for updates" button is independent and works either way.
WATCHTOWER_PERIODIC_POLLS=false
WATCHTOWER_POLL_INTERVAL=86400

# ----- Verification loop (prod-only) ---------------------------------------

# The verification-loop kanban on /admin renders a 🧪 "open on
# staging" link for each feedback card so the operator can one-click
# from "this is the bug on prod" to "let me look at the same path
# on the staging build with the fix on it."  Set this on PROD to
# the public URL of your staging deployment; leave it unset on the
# staging box itself (the rewrite is meaningless there).
#
# See CICD.md → "verification loop" for the full flow.  The Jinja
# helper that uses this value also refuses to rewrite cross-origin
# source URLs as defense in depth, so a malicious source_url
# can't redirect operators to a third party.
STASH_STAGING_URL=

# ----- Google OAuth (oauth2-proxy) -------------------------------------------

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Client ID (Web application).  Set the redirect URI on that client to:
#   https://<DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# Cookie signing secret.  Generate with one of:
#   openssl rand -base64 32 | tr -- '+/' '-_'
#   python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
# Rotating this value invalidates every issued cookie — use that as the "kill
# all active sessions" lever if you ever need it.
OAUTH2_PROXY_COOKIE_SECRET=

# ----- Encryption at rest --------------------------------------------------

# REQUIRED.  Master key that wraps every tenant's per-tenant DEK; without it,
# stash refuses to boot.  Photos and thumbnails on disk are AES-256-GCM
# ciphertext under this key, so a casual `cat` on /data/uploads returns
# nothing readable.  See spec § "Encryption at rest".
#
# Generate one with:
#   python3 -c "import base64,secrets; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# Back this value up to a DIFFERENT bucket / vendor than the data backups.
# Co-locating them defeats the whole separation.  Losing the KEK is total
# data loss — there is no recovery path.  Treat it like a database root
# password.
STASH_KEK=

# ----- Multi-tenancy -------------------------------------------------------

# First-time bootstrap only.  When upgrading an existing single-user deploy
# to multi-tenancy, stash creates a "Personal" tenant and adds this email as
# its sole maintainer member.  After the upgrade has run once, this variable
# is unused and can be removed; further membership changes go through the
# in-app invite flow.
#
# If unset on first upgrade, stash falls back to the first entry of the
# legacy STASH_ALLOWED_EMAILS variable below — so an existing deploy with
# the old email-gate config doesn't need new env vars to upgrade cleanly.
STASH_BOOTSTRAP_MEMBER_EMAIL=

# Operator emails — comma-separated.  These accounts can hit /admin (the
# operator dashboard for cross-tenant metadata, lifecycle controls, vendor
# cost panel) but get NO automatic access to any tenant's data.  Operators
# wanting to see a tenant's content must be invited as a maintainer by
# the tenant, same path as a partner.
STASH_OPERATOR_EMAILS=

# ----- Off-site backups (Backblaze B2) -------------------------------------

# Optional but strongly recommended.  When set, an operator can upload a
# tenant's encrypted backup zip to B2 from /admin (manual trigger today;
# nightly cron lands later — see roadmap step 8 in spec.md).  Without these,
# the in-app /usage/backup download is your only off-deploy copy.
#
# Get the credentials from your Backblaze account:
#   App Keys → Add a New Application Key → restrict to one bucket.
# B2_ENDPOINT is the S3-compatible URL Backblaze prints when you create
# the bucket — looks like https://s3.us-west-002.backblazeb2.com.
#
# Hard rule (spec § "Backups · Off-site DR"): the KEK lives in a SEPARATE
# bucket — and ideally a separate vendor — than the data.  Never set
# B2_BUCKET to the bucket where you stashed the KEK.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_ENDPOINT=
B2_BUCKET=

# ----- Legacy (used only by the multi-tenancy migration) -------------------

# Pre-multi-tenancy gate.  Stash no longer reads this at runtime, but the
# one-shot migration falls back to its first entry as the bootstrap member
# email if STASH_BOOTSTRAP_MEMBER_EMAIL is unset.  After the migration runs
# once, this variable is dead config and can be removed.
STASH_ALLOWED_EMAILS=

# ----- Public-facing /about pages (Stripe KYC, transparency) ---------------

# Stash exposes /about, /about/pricing, /about/refunds, /about/privacy,
# /about/terms, /about/sub-processors, /about/contact without a Google
# sign-in.  Stripe (and any KYC-grade financial partner) requires the
# business name + customer-service contact to be on a public page.
#
# STASH_PUBLIC_BUSINESS_NAME is your legal / display business name as it
# appears on Stripe and elsewhere.  Defaults to "Stash" when unset.
STASH_PUBLIC_BUSINESS_NAME=Stash

# STASH_PUBLIC_CONTACT_EMAIL is the customer-service address rendered on
# the /about pages.  Stripe checks this is reachable.  Defaults to
# support@<your DOMAIN> when unset, which is fine if your mail provider
# catches that address.
STASH_PUBLIC_CONTACT_EMAIL=

# ----- Stripe billing (Pro tier) -------------------------------------------

# Required for the /usage upgrade flow to render.  Without all three set,
# Stash hides the "Upgrade to Pro" CTA cleanly + the webhook route 503s.
#
# STRIPE_SECRET_KEY: your platform-mode secret (sk_live_... in prod,
#   sk_test_... in test mode).
# STRIPE_WEBHOOK_SECRET: from Stripe Dashboard → Developers → Webhooks
#   → endpoint signing secret (whsec_...).  Register the endpoint
#   https://<DOMAIN>/webhooks/stripe subscribing to:
#     checkout.session.completed
#     customer.subscription.updated
#     customer.subscription.deleted
#     invoice.payment_failed
# STRIPE_PRICE_ID_PRO: the price object id for the Pro tier
#   (price_..., recurring monthly).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
