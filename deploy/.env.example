# =============================================================================
# Stash deploy config
# Copy to .env and fill in.  Anything sensitive lives here, not in git.
# =============================================================================

# ----- Domain & TLS ----------------------------------------------------------

# The hostname you'll visit in the browser.  Must have a DNS A record pointing
# at this server's public IP before you start the stack — Caddy needs to
# answer an ACME HTTP-01 challenge on :80 to get a Let's Encrypt cert.
DOMAIN=stash.example.com

# Used for Let's Encrypt account registration + cert expiry warnings.
ACME_EMAIL=you@example.com

# ----- Image -----------------------------------------------------------------

# Pin to a version (vX.Y.Z) for stable deploys, or use :latest to follow main.
STASH_IMAGE=ghcr.io/brennan-vanderlaan/stash:latest

# ----- App secrets -----------------------------------------------------------

# Same values you use locally — copy from your dev .env.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ----- In-app updates --------------------------------------------------------

# Shared secret between stash and watchtower for the "Check for updates"
# button.  Generate with:  openssl rand -hex 32
WATCHTOWER_TOKEN=changeme

# ----- Google OAuth (oauth2-proxy) -------------------------------------------

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Client ID (Web application).  Set the redirect URI on that client to:
#   https://<DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# Cookie signing secret.  Generate with one of:
#   openssl rand -base64 32 | tr -- '+/' '-_'
#   python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
# Rotating this value invalidates every issued cookie — use that as the "kill
# all active sessions" lever if you ever need it.
OAUTH2_PROXY_COOKIE_SECRET=

# ----- Encryption at rest --------------------------------------------------

# REQUIRED.  Master key that wraps every tenant's per-tenant DEK; without it,
# stash refuses to boot.  Photos and thumbnails on disk are AES-256-GCM
# ciphertext under this key, so a casual `cat` on /data/uploads returns
# nothing readable.  See spec § "Encryption at rest".
#
# Generate one with:
#   python3 -c "import base64,secrets; print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# Back this value up to a DIFFERENT bucket / vendor than the data backups.
# Co-locating them defeats the whole separation.  Losing the KEK is total
# data loss — there is no recovery path.  Treat it like a database root
# password.
STASH_KEK=

# ----- Multi-tenancy -------------------------------------------------------

# First-time bootstrap only.  When upgrading an existing single-user deploy
# to multi-tenancy, stash creates a "Personal" tenant and adds this email as
# its sole maintainer member.  After the upgrade has run once, this variable
# is unused and can be removed; further membership changes go through the
# in-app invite flow.
#
# If unset on first upgrade, stash falls back to the first entry of the
# legacy STASH_ALLOWED_EMAILS variable below — so an existing deploy with
# the old email-gate config doesn't need new env vars to upgrade cleanly.
STASH_BOOTSTRAP_MEMBER_EMAIL=

# Operator emails — comma-separated.  These accounts can hit /admin (the
# operator dashboard for cross-tenant metadata, lifecycle controls, vendor
# cost panel) but get NO automatic access to any tenant's data.  Operators
# wanting to see a tenant's content must be invited as a maintainer by
# the tenant, same path as a partner.
STASH_OPERATOR_EMAILS=

# ----- Legacy (used only by the multi-tenancy migration) -------------------

# Pre-multi-tenancy gate.  Stash no longer reads this at runtime, but the
# one-shot migration falls back to its first entry as the bootstrap member
# email if STASH_BOOTSTRAP_MEMBER_EMAIL is unset.  After the migration runs
# once, this variable is dead config and can be removed.
STASH_ALLOWED_EMAILS=
